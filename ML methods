import pandas as pd
import numpy as np
from sklearn.linear_model import LinearRegression
import matplotlib.pyplot as plt
from sklearn.tree import DecisionTreeRegressor
from sklearn.tree import DecisionTreeClassifier
from sklearn.metrics import accuracy_score

#read the merged dataset
df = pd.read_csv("gold_oil_gpr_merged.csv")

#// Lineer Regression


for col in ['Change %_x', 'Change %_y']:
    # First convert to str, erase the '%' sign and then convert to float.
    df[col] = pd.to_numeric(df[col].astype(str).str.replace('%', ''), errors='coerce')

# First convert to str, then erase the comma and finally, convert to float.
df['GPRD'] = pd.to_numeric(df['GPRD'].astype(str).str.replace(',', ''), errors='coerce')

# Create a 'change in percentage' column fot GPRD data
df['GPR_Change_Pct'] = df['GPRD'].pct_change() * 100

#  Drop NaN values
df = df.dropna(subset=['Change %_x', 'Change %_y', 'GPR_Change_Pct'])

#  Determine X (Change in % for oil prices and GPR) and Y (Change in % for gold prices)
#  Try to predict gold prices though investigations into oil prices and gdp


X = df[['Change %_y', 'GPR_Change_Pct']] 
y = df['Change %_x']                      

# Split the data as training(%80) and testing (%20) data
split_index = int(len(df) * 0.8)

# Split the X into test and train data
X_train = X.iloc[:split_index]
X_test = X.iloc[split_index:]

# Split the Y into test and train data
y_train = y.iloc[:split_index]
y_test = y.iloc[split_index:]


# 5. Model Eğitimi
lr_model = LinearRegression()
lr_model.fit(X_train, y_train)

# 6. Tahmin ve Değerlendirme
y_pred = lr_model.predict(X_test)

# Calculate Root Mean Squared Error to test the predicted data
RMSE = np.sum((y_test - y_pred)**2)



print(f"RMSE: {RMSE:.4f}")


# // Decision Tree 
# Create a new column that holds the information wheter gold price increases or decreases 
df['Gold_Direction'] = (df['Change %_x'] > 0).astype(int)

# This variable is new target 
y_class = df['Gold_Direction']

# Slice the data again as train and test for decision tree model    
y_train_cls = y_class.iloc[:split_index]
y_test_cls = y_class.iloc[split_index:]

#Create the model
clf_model = DecisionTreeClassifier(criterion='entropy', max_depth=5, random_state=1) #Choosing appropriate max depth is crucial to avoid overfitting 

#Train the data
clf_model.fit(X_train, y_train_cls)
#Prediction
y_pred_cls = clf_model.predict(X_test)

print(f"Accuracy: {accuracy_score(y_test_cls, y_pred_cls):.4f}")